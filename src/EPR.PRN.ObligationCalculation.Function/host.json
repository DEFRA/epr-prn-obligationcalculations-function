{
    "version": "2.0",
    "logging": {
        "logLevel": {
            "default": "Information",
            "Microsoft": "Warning",
            "System": "Warning",
            "Azure.Identity": "Warning",
            "Azure.Core": "Warning",
            "Function.HealthCheck": "Warning"
        },
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": false
            },
            "enableLiveMetricsFilters": true
        }
    },
    "extensions": {
        "serviceBus": {
            "maxConcurrentCalls": 1,
            "prefetchCount": 1
        }
    }
}